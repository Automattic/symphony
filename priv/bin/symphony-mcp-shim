#!/usr/bin/env elixir

defmodule SymphonyMcpShim do
  @moduledoc false

  def main(args) do
    # Keep stdin byte-oriented: MCP payloads are UTF-8 JSON, and the default
    # unicode/latin1 translation makes IO.binstream raise
    # {:no_translation, :unicode, :latin1} on any multi-byte character,
    # which kills the connection ("MCP error -32000: Connection closed").
    :ok = :io.setopts(:standard_io, encoding: :latin1)

    with {:ok, endpoint, token} <- parse_args(args),
         {:ok, socket} <- open_socket(endpoint),
         :ok <- connect_socket(socket, endpoint),
         :ok <- send_auth(socket, token, endpoint) do
      pump(socket)
    else
      {:error, reason} ->
        IO.puts(:stderr, "symphony-mcp-shim failed: #{inspect(reason)}")
        System.halt(1)
    end
  end

  defp parse_args(args), do: parse_args(args, nil)

  defp parse_args(["--socket", socket_path | rest], _endpoint), do: parse_args(rest, {:unix, socket_path})

  defp parse_args(["--tcp-host", host, "--tcp-port", port | rest], _endpoint) do
    with {:ok, addr} <- parse_tcp_host(host),
         {:ok, port} <- parse_tcp_port(port) do
      parse_args(rest, {:tcp, addr, port})
    else
      {:error, reason} -> {:error, {:invalid_tcp_endpoint_args, reason}}
    end
  end

  defp parse_args([], endpoint) when not is_nil(endpoint) do
    case System.get_env("SYMPHONY_MCP_SESSION_TOKEN") do
      token when is_binary(token) and token != "" -> {:ok, endpoint, token}
      _missing -> {:error, :missing_session_token}
    end
  end

  defp parse_args(_args, _endpoint), do: {:error, :invalid_arguments}

  defp parse_tcp_host("127.0.0.1"), do: {:ok, {127, 0, 0, 1}}
  defp parse_tcp_host("localhost"), do: {:ok, {127, 0, 0, 1}}
  defp parse_tcp_host(host), do: {:error, {:unsupported_tcp_host, host}}

  defp parse_tcp_port(port) do
    case Integer.parse(port) do
      {port, ""} when port in 1..65_535 -> {:ok, port}
      _invalid -> {:error, {:invalid_tcp_port, port}}
    end
  end

  defp open_socket({:unix, _path} = endpoint), do: open_socket(endpoint, :local)
  defp open_socket({:tcp, _addr, _port} = endpoint), do: open_socket(endpoint, :inet)

  defp open_socket(endpoint, family) do
    case :socket.open(family, :stream) do
      {:ok, socket} ->
        {:ok, socket}

      {:error, reason} ->
        log_transport("open_failed", endpoint, reason)
        {:error, {:socket_open_failed, reason}}
    end
  end

  defp connect_socket(socket, {:unix, socket_path}) do
    connect_socket(socket, {:unix, socket_path}, %{family: :local, path: socket_path})
  end

  defp connect_socket(socket, {:tcp, addr, port}) do
    connect_socket(socket, {:tcp, addr, port}, %{family: :inet, addr: addr, port: port})
  end

  defp connect_socket(socket, endpoint, address) do
    case :socket.connect(socket, address) do
      :ok ->
        :ok

      {:error, reason} ->
        log_transport("connect_failed", endpoint, reason)
        {:error, {:socket_connect_failed, endpoint_label(endpoint), reason}}
    end
  end

  defp send_auth(socket, token, endpoint) do
    case :socket.send(socket, "symphony-session-token: #{token}\r\n\r\n") do
      :ok ->
        :ok

      {:error, reason} ->
        log_transport("auth_send_failed", endpoint, reason)
        {:error, {:socket_auth_send_failed, reason}}
    end
  end

  defp pump(socket) do
    parent = self()
    spawn_link(fn -> stdin_to_socket(socket, parent) end)
    spawn_link(fn -> socket_to_stdout(socket, parent) end)
    wait_for_completion(socket)
  end

  # MCP stdio transport is newline-delimited JSON: each message is one line.
  # Read line-by-line so we forward each message as soon as Claude flushes it,
  # rather than buffering until a fixed chunk size fills.
  defp stdin_to_socket(socket, parent) do
    IO.binstream(:stdio, :line)
    |> Enum.reduce_while(:ok, fn line, :ok ->
      case :socket.send(socket, line) do
        :ok ->
          {:cont, :ok}

        {:error, reason} ->
          IO.puts(:stderr, "symphony-mcp-shim transport event=stdin_send_failed bytes=#{byte_size(line)} reason=#{inspect(reason)}")
          {:halt, {:error, reason}}
      end
    end)

    shutdown_write(socket)
    send(parent, :stdin_done)
  end

  defp socket_to_stdout(socket, parent) do
    socket
    |> socket_stream()
    |> Enum.each(fn chunk -> IO.binwrite(:stdio, chunk) end)

    send(parent, :socket_done)
  end

  defp socket_stream(socket) do
    Stream.resource(
      fn -> socket end,
      fn socket ->
        case :socket.recv(socket) do
          {:ok, data} -> {[data], socket}
          {:error, reason} ->
            IO.puts(:stderr, "symphony-mcp-shim transport event=socket_recv_stopped reason=#{inspect(reason)}")
            {:halt, socket}
        end
      end,
      fn _socket -> :ok end
    )
  end

  defp wait_for_completion(socket) do
    receive do
      :socket_done ->
        :socket.close(socket)
        :ok

      :stdin_done ->
        wait_for_completion(socket)
    end
  end

  defp shutdown_write(socket) do
    :socket.shutdown(socket, :write)
  catch
    :error, _reason -> :ok
  end

  defp log_transport(event, endpoint, reason) do
    IO.puts(
      :stderr,
      "symphony-mcp-shim transport event=#{event} endpoint=#{endpoint_label(endpoint)} reason=#{inspect(reason)}"
    )
  end

  defp endpoint_label({:unix, _path}), do: "unix"
  defp endpoint_label({:tcp, _addr, _port}), do: "tcp"
end

SymphonyMcpShim.main(System.argv())
